# Zeroclaw WebSocket 配置
ZEROCLAW_WS_URL=ws://127.0.0.1:42617/ws/chat
ZEROCLAW_WEBHOOK_BEARER=

# 企业微信配置
WECOM_TOKEN=your_wecom_token
WECOM_AES_KEY=your_aes_key
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_APP_SECRET=your_app_secret

# 允许的用户列表（逗号分隔，留空表示允许所有用户）
WECOM_ALLOWED_USERS=

# 消息分割阈值（字节）
# 企业微信客户端：2048 字节
# 微信端（企业微信插件）：约 600-800 字节（实测）
# 推荐值：600-800（微信端）或 1800（仅企业微信客户端）
WECOM_MAX_MESSAGE_BYTES=800

# 监听配置
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080
